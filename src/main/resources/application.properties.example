# 1. Database Configuration
spring.datasource.url=jdbc:mysql://localhost:3306/online_exam_db
spring.datasource.username=root
# Change the line below to the password placeholder
spring.datasource.password=YOUR_DB_PASSWORD_HERE

# 2. Hibernate settings (safe to keep)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# 3. JWT Configuration
# Change the line below to the secret placeholder
jwt.secret=YOUR_LONG_RANDOM_SECRET_KEY_HERE
jwt.access.validity=604800000
jwt.refresh.validity=2592000000